<%- include("partials/header.ejs") %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><%= title %></h2>
    <p class="text-muted mb-0">Click an author name to see full author details.</p>
  </div>
  <a href="/" class="btn btn-outline-secondary">Back Home</a>
</div>

<% if (!quotes.length) { %>
  <div class="alert alert-warning shadow-sm">
    No quotes found.
  </div>
<% } %>

<div class="row g-4">
  <% for (let q of quotes) { %>
    <div class="col-md-6">
      <div class="card quote-card shadow-sm h-100">
        <div class="card-body p-4">
          <blockquote class="blockquote mb-3">
            “<%= q.quote %>”
          </blockquote>

          <p class="mb-2">
            <button
              class="btn btn-link p-0 authorLink text-decoration-none fw-semibold"
              data-authorid="<%= q.authorId %>"
              data-bs-toggle="modal"
              data-bs-target="#authorModal">
              <%= q.firstName %> <%= q.lastName %>
            </button>
          </p>

          <div class="d-flex justify-content-between text-muted small">
            <span>Category: <%= q.category %></span>
            <span>Likes: <%= q.likes %></span>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</div>

<div class="modal fade" id="authorModal" tabindex="-1" aria-labelledby="authorModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h1 class="modal-title fs-5" id="authorModalLabel">Author Information</h1>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="authorInfo">
        Loading...
      </div>
    </div>
  </div>
</div>

<script src="/js/scripts.js"></script>

<%- include("partials/footer.ejs") %>
