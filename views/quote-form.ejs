<%- include("partials/header.ejs") %>

<div class="card shadow-sm">
  <div class="card-body p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h2 mb-0"><%= pageTitle %></h1>
      <a href="/quotes" class="btn btn-outline-secondary">Back to Quotes</a>
    </div>

    <form action="<%= formAction %>" method="post">
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label">Quote</label>
          <textarea name="quote" rows="4" class="form-control" required><%= quote.quote || '' %></textarea>
        </div>

        <div class="col-md-6">
          <label class="form-label">Author</label>
          <select name="authorId" class="form-select" required>
            <option value="">Select an author</option>
            <% for (let a of authors) { %>
              <option value="<%= a.authorId %>" <%= String(quote.authorId) === String(a.authorId) ? 'selected' : '' %>>
                <%= a.firstName %> <%= a.lastName %>
              </option>
            <% } %>
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label">Category</label>
          <input list="categoryList" name="category" class="form-control" value="<%= quote.category || '' %>" required>
          <datalist id="categoryList">
            <% for (let category of categories) { %>
              <option value="<%= category %>"></option>
            <% } %>
          </datalist>
        </div>

        <div class="col-md-4">
          <label class="form-label">Likes</label>
          <input type="number" name="likes" min="0" class="form-control" value="<%= quote.likes ?? 0 %>" required>
        </div>
      </div>

      <div class="mt-4">
        <button class="btn btn-primary">Save Quote</button>
      </div>
    </form>
  </div>
</div>

<%- include("partials/footer.ejs") %>
